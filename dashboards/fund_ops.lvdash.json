              {
                "name": "main_query",
                "query": {
                  "datasetName": "ds_calls",
                  "fields": [
                    {
                      "name": "calls",
                      "expression": "COUNT(`file_name`)"
                    }
                  ],
                  "disaggregated": false
                }
              }
            ],
            "spec": {
              "version": 2,
              "widgetType": "counter",
              "encodings": {
                "value": {
                  "fieldName": "calls",
                  "displayName": "Capital calls"
                }
